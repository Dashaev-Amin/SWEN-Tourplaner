{
  "info": {
    "name": "MRP API",
    "_postman_id": "d51f6e7d-4b2b-4b1d-8c5a-9f9bfe2f0b8f",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const defaults = {",
          "  baseUrl: \"http://localhost:8080/api\",",
          "  username: \"demo\",",
          "  password: \"demo\",",
          "  username2: \"demo2\",",
          "  password2: \"demo2\"",
          "};",
          "Object.entries(defaults).forEach(([k, v]) => {",
          "  const current = pm.collectionVariables.get(k);",
          "  if (!current) pm.collectionVariables.set(k, v);",
          "});",
          "const aliases = {",
          "  \"username?\": \"username\",",
          "  \"password?\": \"password\",",
          "  \"username2?\": \"username2\",",
          "  \"password2?\": \"password2\"",
          "};",
          "Object.entries(aliases).forEach(([alias, key]) => {",
          "  const current = pm.collectionVariables.get(alias);",
          "  if (!current) {",
          "    const value = pm.collectionVariables.get(key);",
          "    if (value) pm.collectionVariables.set(alias, value);",
          "  }",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 Register User 1",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"Username\": \"{{username}}\",\n  \"Password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/register",
          "host": ["{{baseUrl}}"],
          "path": ["users", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"register user1 ok\", function () {",
              "  pm.expect([201, 409]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
