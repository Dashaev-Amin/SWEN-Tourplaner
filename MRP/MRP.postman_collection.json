    {
      "name": "04 Update Profile User 1",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"displayName\": \"Demo User\",\n  \"bio\": \"Likes sci-fi\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/{{username}}/profile",
          "host": ["{{baseUrl}}"],
          "path": ["users", "{{username}}", "profile"]
        }
      }
    },
    {
      "name": "05 Create Media",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Matrix\",\n  \"description\": \"SciFi\",\n  \"mediaType\": 0,\n  \"releaseYear\": 1999,\n  \"genres\": [\"SciFi\"],\n  \"ageRestriction\": 16\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/media",
          "host": ["{{baseUrl}}"],
          "path": ["media"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"create media ok\", function () {",
              "  pm.expect(pm.response.code).to.equal(201);",
              "});",
              "var data = pm.response.json();",
              "var mediaId = data.Id || data.id;",
              "pm.collectionVariables.set(\"mediaId\", mediaId);"
            ]
          }
        }
      ]
    },
    {
