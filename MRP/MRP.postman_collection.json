        ],
        "url": {
          "raw": "{{baseUrl}}/media?title=mat&sortBy=title",
          "host": ["{{baseUrl}}"],
          "path": ["media"],
          "query": [
            { "key": "title", "value": "mat" },
            { "key": "sortBy", "value": "title" }
          ]
        }
      }
